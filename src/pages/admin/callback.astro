---
export const prerender = false;

import { signJWT, setSessionCookie } from "../../lib/auth";

const code = Astro.url.searchParams.get("code");
if (!code) {
    return Astro.redirect("/admin/login?error=no_code");
}

// Exchange code for access token
const tokenRes = await fetch("https://github.com/login/oauth/access_token", {
    method: "POST",
    headers: { "Content-Type": "application/json", Accept: "application/json" },
    body: JSON.stringify({
        client_id: import.meta.env.GITHUB_CLIENT_ID,
        client_secret: import.meta.env.GITHUB_CLIENT_SECRET,
        code,
    }),
});

if (!tokenRes.ok) {
    return Astro.redirect("/admin/login?error=token_failed");
}

const tokenData = await tokenRes.json() as { access_token?: string; error?: string };
if (!tokenData.access_token || tokenData.error) {
    return Astro.redirect("/admin/login?error=token_failed");
}

// Fetch GitHub user info
const userRes = await fetch("https://api.github.com/user", {
    headers: {
        Authorization: `Bearer ${tokenData.access_token}`,
        Accept: "application/vnd.github.v3+json",
    },
});

if (!userRes.ok) {
    return Astro.redirect("/admin/login?error=user_failed");
}

const ghUser = await userRes.json() as { id: number; login: string };

// Verify it's the admin
if (ghUser.login !== import.meta.env.GITHUB_USERNAME) {
    return Astro.redirect("/admin/login?error=unauthorized");
}

// Create JWT and set cookie
const token = await signJWT(
    { sub: String(ghUser.id), login: ghUser.login },
    import.meta.env.JWT_SECRET
);
setSessionCookie(Astro.cookies, token);

return Astro.redirect("/admin/dashboard");
---
